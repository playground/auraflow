node_modules/
dist/
build/
xs_*/
*.log
.DS_Store
.env
.env.local
.vscode/
.idea/

# web/bin/*.bin IS tracked — those are the flasher's published payload,
# refreshed by `npm run publish:flasher`. The raw build/ output below
# stays untracked.

# ESP-IDF (C firmware build artifacts under src/firmware/c/)
src/firmware/c/build/
src/firmware/c/sdkconfig
src/firmware/c/sdkconfig.old
src/firmware/c/managed_components/
src/firmware/c/dependencies.lock

# Host-side C test binaries (compiled by src/firmware/c/test/Makefile)
src/firmware/c/test/test_*
!src/firmware/c/test/test_*.c
!src/firmware/c/test/test_*.h
