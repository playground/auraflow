{
  "include": [
    "$(MODDABLE)/examples/manifest_base.json",
    "$(MODDABLE)/examples/manifest_net.json",
    "$(MODDABLE)/modules/network/wifi/manifest.json",
    "$(MODDABLE)/modules/network/sntp/manifest.json",
    "$(MODDABLE)/modules/data/preference/manifest.json",
    "$(MODDABLE)/modules/io/manifest.json",
    "$(MODDABLE)/modules/network/fetch/manifest.json"
  ],
  "modules": {
    "*": [
      "./src/firmware/modbus",
      "./src/firmware/tuf2000m",
      "./src/firmware/ring-buffer",
      "./src/firmware/uplink",
      "./src/firmware/nvs",
      "./src/firmware/wifi",
      "./src/firmware/main"
    ]
  },
  "preload": [
    "modbus",
    "tuf2000m",
    "ring-buffer",
    "uplink"
  ],
  "config": {
    "main": "main"
  },
  "platforms": {
    "esp32": {
      "modules": {
        "*": "$(MODULES)/io/digital/digital"
      }
    }
  }
}
